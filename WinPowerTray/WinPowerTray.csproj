<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AssemblyName>WinPowerTray</AssemblyName>
    <RootNamespace>WinPowerTray</RootNamespace>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Description>Windows 11 system tray app to switch power modes</Description>
    <Copyright>Copyright (c) 2026 hello-world-dot-c</Copyright>
    <!-- Produce a single self-contained exe for easy distribution -->
    <SelfContained>false</SelfContained>
    <!-- Suppress the console window entirely -->
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <!-- Suppress legacy designer warning on .NET 8 WinForms -->
  <PropertyGroup>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

</Project>
